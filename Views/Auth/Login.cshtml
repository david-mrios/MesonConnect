@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "login-page";

}

<section class="login-section">

    <div class="login-wrapper">

        <div class="card-login">

            <div class="form-container">

                <!-- LOGIN -->
                <form id="loginForm" class="active" method="post" asp-action="Login">
                    <h2>Welcome Back 👋</h2>

                    <div class="input-group">
                        <input type="text" name="username" required />
                        <label>Username</label>
                    </div>

                    <div class="input-group">
                        <input type="password" name="password" required />
                        <label>Password</label>
                    </div>

                    <button type="submit">Login</button>

                    <p class="switch-text">
                        Don’t have an account?
                        <span onclick="showSignup()">Sign Up</span>
                    </p>
                </form>

                <!-- SIGNUP -->
                <form id="signupForm" class="hidden" method="post" asp-action="Register">
                    <h2>Create Account 🚀</h2>

                    <div class="input-group">
                        <input type="text" name="name" required />
                        <label>Full Name</label>
                    </div>

                    <div class="input-group">
                        <input type="email" name="email" required />
                        <label>Email</label>
                    </div>

                    <div class="input-group">
                        <input type="password" name="password" required />
                        <label>Password</label>
                    </div>

                    <button type="submit">Sign Up</button>

                    <p class="switch-text">
                        Already have an account?
                        <span onclick="showLogin()">Login</span>
                    </p>
                </form>

            </div>

        </div>

    </div>

</section>

<style>

    /* 🔥 FONDO CON IMAGEN PRO */
    .login-section {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: transparent; /* CLAVE 🔥 */
        position: relative;
        z-index: 0; /* 🔥 lo mandas atrás */
        overflow: visible;
    }

    .header {
        position: relative;
        z-index: 1000; /* 🔥 header arriba */
    }



    .login-page {
        background:url('https://images.unsplash.com/photo-1550547660-d9450f859349');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

        /* HEADER SOLO VISUAL (NO ESTRUCTURA) */
        .login-page .header {
            background: transparent;
            box-shadow: none;
        }

            /* TEXTO NORMAL */
            .login-page .header .logo,
            .login-page .header .navmenu a,
            .login-page .header .sitename {
                color: #fff;
            }

                /* HOVER SOLO EN LINKS (NO TODO EL HEADER) */
                .login-page .header .navmenu a:hover {
                    color: #ff4d4d;
                }

            /* LOGO DESTACADO */
            .login-page .header .sitename {
                color: #ffffff;
                font-weight: bold;
            }

            /* BOTONES (LOGIN + BOOK A TABLE) */
            .login-page .header .btn,
            .login-page .header .btn-getstarted {
                background: linear-gradient(45deg, #dc3545, #ff4d4d);
                color: white;
                border: none;
                border-radius: 30px;
                padding: 8px 20px;
                font-weight: 500;
                transition: all 0.3s ease;
            }

                /* HOVER BOTONES */
                .login-page .header .btn:hover,
                .login-page .header .btn-getstarted:hover {
                    background: linear-gradient(45deg, #b02a37, #dc3545);
                    transform: translateY(-2px);
                    box-shadow: 0 5px 15px rgba(220,53,69,0.4);
                }

        /* 🔥 CUANDO EL MENU MOBILE ESTÁ ABIERTO → RESET */
        .login-page.mobile-nav-active .header,
        .login-page.mobile-nav-active .header a,
        .login-page.mobile-nav-active .header .sitename {
            color: var(--nav-dropdown-color) !important;
        }

        /* FONDO NORMAL DEL MENU */
        .login-page.mobile-nav-active .navmenu ul {
            background: var(--nav-mobile-background-color) !important;
        }

    /* CARD */
    .card-login {
        backdrop-filter: none;
        background: rgba(255,255,255,0.75);
        padding: 40px;
        border-radius: 20px;
        width: 350px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    /* FORM */
    .form-container {
        position: relative;
        height: 340px;
    }

        .form-container form {
            position: absolute;
            width: 100%;
            transition: all 0.4s ease;
        }

    /* STATES */
    .active {
        opacity: 1;
        transform: translateX(0);
        pointer-events: all;
    }

    .hidden {
        opacity: 0;
        transform: translateX(40px);
        pointer-events: none;
    }

    /* INPUT MODERNO */
    .input-group {
        position: relative;
        margin-bottom: 20px;
    }

        .input-group input {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            outline: none;
            background: #f1f1f1;
        }

        .input-group label {
            position: absolute;
            left: 12px;
            top: 12px;
            color: #888;
            transition: 0.3s;
        }

        .input-group input:focus + label,
        .input-group input:valid + label {
            top: -8px;
            left: 8px;
            font-size: 12px;
            color: #dc3545;
            background: white;
            padding: 0 5px;
        }

    /* BUTTON */
    button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: linear-gradient(45deg, #dc3545, #ff4d4d);
        color: white;
        font-weight: bold;
        transition: 0.3s;
    }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(220,53,69,0.4);
        }

    /* TEXT */
    .switch-text {
        text-align: center;
        margin-top: 15px;
    }

        .switch-text span {
            color: #dc3545;
            font-weight: bold;
            cursor: pointer;
        }


</style>

<script>
    function showSignup() {
        document.getElementById("loginForm").classList.replace("active", "hidden");
        document.getElementById("signupForm").classList.replace("hidden", "active");
    }

    function showLogin() {
        document.getElementById("signupForm").classList.replace("active", "hidden");
        document.getElementById("loginForm").classList.replace("hidden", "active");
    }
</script>

