                    "delay": 3000,
                    "disableOnInteraction": false
                  },
                  "slidesPerView": 3,
                  "spaceBetween": 20,
                  "centeredSlides": true,
                  "pagination": {
                    "el": ".swiper-pagination",
                    "type": "bullets",
                    "clickable": true
                  },
                  "breakpoints": {
                    "320": { "slidesPerView": 1, "spaceBetween": 10 },
                    "768": { "slidesPerView": 3, "spaceBetween": 20 },
                    "1200": { "slidesPerView": 5, "spaceBetween": 20 }
