<section id="events" class="events section">

    <div class="container-fluid">

        <div class="swiper">

            <div class="swiper-wrapper">

                <div class="swiper-slide event-item"
                     data-title="Combo Familiar"
                     data-price="$25"
                     data-desc="Hamburguesas, papas y bebidas para compartir en familia."
                     style="background-image: url('@Url.Content("~/assets/img/events-1.jpg")')">

                    <h3>Combo Familiar</h3>
                    <div class="price">$25</div>
                </div>

                <div class="swiper-slide event-item"
                     data-title="Promoción 2x1"
                     data-price="$10"
                     data-desc="Disfruta nuestras hamburguesas en promoción especial."
                     style="background-image: url('@Url.Content("~/assets/img/events-2.jpg")')">

                    <h3>Promoción 2x1</h3>
                    <div class="price">$10</div>
                </div>

                <div class="swiper-slide event-item"
                     data-title="Cumpleaños Express"
                     data-price="$50"
                     data-desc="Celebra tu cumpleaños con combos y ambiente especial."
                     style="background-image: url('@Url.Content("~/assets/img/events-3.jpg")')">

                    <h3>Cumpleaños Express</h3>
                    <div class="price">$50</div>
                </div>

                <div class="swiper-slide event-item"
                     data-title="Pedidos por WhatsApp"
                     data-price="Desde $5"
                     data-desc="Haz tu pedido rápido por WhatsApp y recíbelo sin esperar."
                     style="background-image: url('@Url.Content("~/assets/img/events-4.jpg")')">

                    <h3>Pedidos por WhatsApp</h3>
                    <div class="price">Desde $5</div>
                </div>

            </div>

            <div class="swiper-pagination"></div>

        </div>

    </div>

</section>

<!-- MODAL PERSONALIZADO -->
<div id="eventModal" class="custom-modal">
    <div class="custom-modal-content">

        <span class="custom-close">&times;</span>

        <div class="custom-modal-body">

            <!-- IZQUIERDA -->
            <div class="custom-form">
                <h2 id="eventTitle"></h2>
                <p id="eventDesc"></p>
                <h3 id="eventPrice"></h3>

                <form id="eventForm">
                    <input type="text" placeholder="Nombre completo" required>
                    <input type="tel" placeholder="Número de WhatsApp" required>
                    <input type="date" required>
                    <input type="number" placeholder="Cantidad de pedidos/personas" required>

                    <textarea placeholder="Ej: sin cebolla, extra queso..."></textarea>

                    <div class="custom-buttons">
                        <button type="submit" class="btn-primary">Hacer Pedido</button>
                        <button type="button" id="cancelBtn" class="btn-cancel">Cancelar</button>
                    </div>
                </form>
            </div>

            <!-- DERECHA -->
            <div class="custom-summary">
                <h2>Resumen</h2>
                <p id="summaryText">Selecciona una opción y completa el formulario.</p>
            </div>

        </div>
    </div>
</div>

<style>
    .event-item {
        height: 300px;
        color: white;
        padding: 20px;
        border-radius: 12px;
        background-size: cover;
        background-position: center;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

        .event-item h3 {
            margin: 0;
            font-size: 24px;
        }

        .event-item .price {
            font-size: 18px;
            background: #ff6600;
            padding: 6px 12px;
            border-radius: 6px;
            margin-top: 8px;
            display: inline-block;
        }

    .custom-modal {
        display: none;
        position: fixed;
        z-index: 999999;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: rgba(0,0,0,0.6);
    }

    .custom-modal-content {
        position: relative;
        width: 85%;
        height: 80%;
        margin: 5% auto;
        background: white;
        border-radius: 20px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        animation: zoomIn 0.3s ease;
    }

    .custom-modal-body {
        display: flex;
        width: 100%;
        height: 100%;
    }

    .custom-form {
        width: 50%;
        padding: 40px;
        background: #fafafa;
        overflow-y: auto;
    }

        .custom-form h2 {
            font-size: 28px;
            margin-bottom: 10px;
        }

        .custom-form p {
            color: #666;
            margin-bottom: 10px;
        }

        .custom-form h3 {
            color: #ff6600;
            margin-bottom: 20px;
        }

    .custom-summary {
        width: 50%;
        padding: 40px;
        background: linear-gradient(135deg, #1e1e1e, #2c2c2c);
        color: white;
    }

        .custom-summary h2 {
            margin-bottom: 20px;
        }

    .custom-form input,
    .custom-form textarea {
        width: 100%;
        padding: 14px;
        margin-bottom: 18px;
        border-radius: 8px;
        border: 1px solid #ccc;
    }

    .custom-buttons {
        display: flex;
        gap: 15px;
    }

    .btn-primary {
        flex: 1;
        padding: 14px;
        background: #ff6600;
        color: white;
        border: none;
        border-radius: 8px;
    }

    .btn-cancel {
        flex: 1;
        padding: 14px;
        background: #999;
        border: none;
        border-radius: 8px;
    }

    .custom-close {
        position: absolute;
        right: 20px;
        top: 15px;
        font-size: 24px;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #eee;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    @@keyframes zoomIn {
        from {
            transform: scale(0.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<script>
    const modal = document.getElementById("eventModal");
    const slides = document.querySelectorAll(".event-item");
    const closeBtn = document.querySelector(".custom-close");

    const title = document.getElementById("eventTitle");
    const desc = document.getElementById("eventDesc");
    const price = document.getElementById("eventPrice");

    const form = document.getElementById("eventForm");
    const summary = document.getElementById("summaryText");
    const cancelBtn = document.getElementById("cancelBtn");

    let currentEvent = {};

    slides.forEach(slide => {
      slide.addEventListener("click", () => {

        currentEvent = {
          title: slide.dataset.title,
          desc: slide.dataset.desc,
          price: slide.dataset.price
        };

        title.innerText = currentEvent.title;
        desc.innerText = currentEvent.desc;
        price.innerText = "Precio: " + currentEvent.price;

        modal.style.display = "block";
      });
    });

    closeBtn.onclick = () => modal.style.display = "none";

    window.onclick = (e) => {
      if (e.target == modal) modal.style.display = "none";
    };

    form.addEventListener("submit", function(e){
      e.preventDefault();

      summary.innerHTML = `
        <h3>✅ Pedido recibido</h3>
        <p>${currentEvent.title}</p>
        <p>${currentEvent.price}</p>
      `;
    });

    cancelBtn.addEventListener("click", () => {
      summary.innerHTML = `<h3>❌ Pedido cancelado</h3>`;
    });
</script>