<section id="menu" class="menu section">

    <!-- Section Title -->
    <div class="container section-title">
        <h2>Menú</h2>
        <p><span>Descubre nuestro</span> <span class="description-title">Menú Rápido</span></p>
    </div>

    <div class="container">

        <!-- Tabs -->
        <ul class="nav nav-tabs d-flex justify-content-center">

            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#menu-starters">
                    <h4>Combos</h4>
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#menu-breakfast">
                    <h4>Desayunos</h4>
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#menu-lunch">
                    <h4>Almuerzos</h4>
                </button>
            </li>

            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#menu-dinner">
                    <h4>Cenas</h4>
                </button>
            </li>

        </ul>

        <!-- Content -->
        <div class="tab-content">

            <!-- COMBOS -->
            <div class="tab-pane fade show active" id="menu-starters">

                <div class="tab-header text-center">
                    <p>Menú</p>
                    <h3>Combos</h3>
                </div>

                <div class="row gy-5">

                    @for (int i = 1; i <= 6; i++)
                    {
                        <div class="col-lg-4 menu-item">
                            <img src="~/assets/img/menu/menu-item-@(i).png" class="menu-img img-fluid" alt="">
                            <h4>Combo Rápido @i</h4>
                            <p class="ingredients">
                                Hamburguesa, papas fritas y bebida
                            </p>
                            <p class="price">
                                $@((i * 5) + 0.95)
                            </p>

                            <button class="btn btn-primary btn-sm add-to-cart"
                                    data-name="Combo Rápido @i"
                                    data-price="@((i * 5) + 0.95)">
                                + Agregar
                            </button>
                        </div>
                    }

                </div>
            </div>

            <!-- DESAYUNOS -->
            <div class="tab-pane fade" id="menu-breakfast">

                <div class="tab-header text-center">
                    <p>Menú</p>
                    <h3>Desayunos</h3>
                </div>

                <div class="row gy-5">

                    @for (int i = 1; i <= 6; i++)
                    {
                        <div class="col-lg-4 menu-item">
                            <img src="~/assets/img/menu/menu-item-@(i).png" class="menu-img img-fluid" alt="">
                            <h4>Desayuno Express @i</h4>
                            <p class="ingredients">
                                Huevos, pan tostado y café
                            </p>
                            <p class="price">
                                $@((i * 4) + 0.95)
                            </p>

                            <button class="btn btn-primary btn-sm add-to-cart"
                                    data-name="Desayuno Express @i"
                                    data-price="@((i * 4) + 0.95)">
                                + Agregar
                            </button>
                        </div>
                    }

                </div>
            </div>

            <!-- ALMUERZOS -->
            <div class="tab-pane fade" id="menu-lunch">

                <div class="tab-header text-center">
                    <p>Menú</p>
                    <h3>Almuerzos</h3>
                </div>

                <div class="row gy-5">

                    @for (int i = 1; i <= 6; i++)
                    {
                        <div class="col-lg-4 menu-item">
                            <img src="~/assets/img/menu/menu-item-@(i).png" class="menu-img img-fluid" alt="">
                            <h4>Almuerzo Rápido @i</h4>
                            <p class="ingredients">
                                Pollo frito con papas o arroz y ensalada
                            </p>
                            <p class="price">
                                $@((i * 6) + 0.95)
                            </p>

                            <button class="btn btn-primary btn-sm add-to-cart"
                                    data-name="Almuerzo Rápido @i"
                                    data-price="@((i * 6) + 0.95)">
                                + Agregar
                            </button>
                        </div>
                    }

                </div>
            </div>

            <!-- CENAS -->
            <div class="tab-pane fade" id="menu-dinner">

                <div class="tab-header text-center">
                    <p>Menú</p>
                    <h3>Cenas</h3>
                </div>

                <div class="row gy-5">

                    @for (int i = 1; i <= 6; i++)
                    {
                        <div class="col-lg-4 menu-item">
                            <img src="~/assets/img/menu/menu-item-@(i).png" class="menu-img img-fluid" alt="">
                            <h4>Cena Rápida @i</h4>
                            <p class="ingredients">
                                Hot dog, hamburguesa o tacos con bebida
                            </p>
                            <p class="price">
                                $@((i * 7) + 0.95)
                            </p>
                        </div>
                    }

                </div>
            </div>

        </div>

    </div>

</section>