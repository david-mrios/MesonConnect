<section id="testimonials" class="testimonials section light-background">

    <div class="container section-title position-relative text-center">

        <!-- Botón -->
        <button class="btn btn-primary d-none d-md-inline-block position-absolute top-0 end-0 mt-2 me-2"
                id="btnAddTestimonial">
            + Agregar Reseña
        </button>

        <!-- Título -->
        <h2>TESTIMONIOS</h2>
        <p>Lo que dicen nuestros <span class="description-title">clientes</span></p>

        <!-- Botón mobile -->
        <div class="d-md-none mt-3">
            <button class="btn btn-primary" id="btnAddTestimonialMobile">
                + Agregar Reseña
            </button>
        </div>

    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="swiper">

            <div class="swiper-wrapper">

                <!-- Item 1 -->
                <div class="swiper-slide">
                    <div class="testimonial-item">
                        <div class="row gy-4 justify-content-center">
                            <div class="col-lg-6">
                                <div class="testimonial-content">
                                    <p>
                                        <i class="bi bi-quote quote-icon-left"></i>
                                        <span>Las hamburguesas son deliciosas y el servicio es rapidísimo.</span>
                                        <i class="bi bi-quote quote-icon-right"></i>
                                    </p>
                                    <h3>Juan Pérez</h3>
                                    <h4>Cliente frecuente</h4>
                                </div>
                            </div>
                            <div class="col-lg-2 text-center">
                                <img src="~/assets/img/testimonials/testimonials-1.jpg" class="img-fluid testimonial-img" alt="">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Item 2 -->
                <div class="swiper-slide">
                    <div class="testimonial-item">
                        <div class="row gy-4 justify-content-center">
                            <div class="col-lg-6">
                                <div class="testimonial-content">
                                    <p>
                                        <i class="bi bi-quote quote-icon-left"></i>
                                        <span>Pedí por WhatsApp y llegó rápido, caliente y muy rico.</span>
                                        <i class="bi bi-quote quote-icon-right"></i>
                                    </p>
                                    <h3>María López</h3>
                                    <h4>Cliente</h4>
                                </div>
                            </div>
                            <div class="col-lg-2 text-center">
                                <img src="~/assets/img/testimonials/testimonials-2.jpg" class="img-fluid testimonial-img" alt="">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Item 3 -->
                <div class="swiper-slide">
                    <div class="testimonial-item">
                        <div class="row gy-4 justify-content-center">
                            <div class="col-lg-6">
                                <div class="testimonial-content">
                                    <p>
                                        <i class="bi bi-quote quote-icon-left"></i>
                                        <span>Buen precio, buena comida y siempre vuelvo con mi familia.</span>
                                        <i class="bi bi-quote quote-icon-right"></i>
                                    </p>
                                    <h3>Carlos Gómez</h3>
                                    <h4>Cliente satisfecho</h4>
                                </div>
                            </div>
                            <div class="col-lg-2 text-center">
                                <img src="~/assets/img/testimonials/testimonials-3.jpg" class="img-fluid testimonial-img" alt="">
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Paginación -->
            <div class="swiper-pagination"></div>

        </div>

    </div>

</section>

<!-- MODAL -->
<div id="testimonialModal" class="modal-testimonial">

    <div class="modal-content">

        <div class="modal-header">
            <h4>Agregar Reseña</h4>
            <button onclick="closeModal()">✖</button>
        </div>

        <input type="text" id="name" placeholder="Tu nombre" class="form-control mb-2">
        <input type="text" id="role" placeholder="Ej: Cliente frecuente" class="form-control mb-2">
        <textarea id="message" placeholder="Cuéntanos tu experiencia..." class="form-control mb-2"></textarea>

        <button class="btn btn-success w-100" onclick="saveTestimonial()">
            Guardar
        </button>

    </div>

</div>

<style>
    /* ===== MODAL FONDO ===== */
    .modal-testimonial {
        display: none;
        position: fixed;
        z-index: 99999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
    }

    /* ===== CONTENIDO ===== */
    .modal-content {
        background: white;
        width: 90%;
        max-width: 400px;
        margin: 10% auto;
        padding: 20px;
        border-radius: 12px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        animation: fadeIn 0.3s ease;
    }

    /* HEADER */
    .modal-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
    }

        .modal-header h4 {
            margin: 0;
        }

        .modal-header button {
            border: none;
            background: none;
            font-size: 18px;
            cursor: pointer;
        }

    /* INPUTS */
    .modal-content input,
    .modal-content textarea {
        width: 100%;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ddd;
        margin-bottom: 10px;
    }

    /* BOTÓN */
    .modal-content .btn-success {
        background: #ff6600;
        border: none;
    }

        .modal-content .btn-success:hover {
            background: #e65c00;
        }

    /* ANIMACIÓN */
    @@keyframes zoomIn {
        from {
            transform: scale(0.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<script>
    // ABRIR MODAL
    document.getElementById("btnAddTestimonial")?.addEventListener("click", openModal);
    document.getElementById("btnAddTestimonialMobile")?.addEventListener("click", openModal);

    function openModal() {
        document.getElementById("testimonialModal").style.display = "block";
    }

    // CERRAR
    function closeModal() {
        document.getElementById("testimonialModal").style.display = "none";
    }

    // GUARDAR
    function saveTestimonial() {

        let name = document.getElementById("name").value;
        let role = document.getElementById("role").value;
        let message = document.getElementById("message").value;

        if (!name || !message) {
            alert("Completa los campos");
            return;
        }

        let images = [
            "/assets/img/testimonials/testimonials-1.jpg",
            "/assets/img/testimonials/testimonials-2.jpg",
            "/assets/img/testimonials/testimonials-3.jpg"
        ];

        let randomImage = images[Math.floor(Math.random() * images.length)];

        let newItem = `
        <div class="swiper-slide">
          <div class="testimonial-item">
              <div class="row gy-4 justify-content-center">

                  <div class="col-lg-6">
                      <div class="testimonial-content">
                          <p>
                              <i class="bi bi-quote quote-icon-left"></i>
                              <span>${message}</span>
                              <i class="bi bi-quote quote-icon-right"></i>
                          </p>
                          <h3>${name}</h3>
                          <h4>${role || 'Cliente'}</h4>
                      </div>
                  </div>

                  <div class="col-lg-2 text-center">
                      <img src="${randomImage}"
                           class="img-fluid testimonial-img"
                           alt="">
                  </div>

              </div>
          </div>
        </div>
        `;

        document.querySelector(".swiper-wrapper").insertAdjacentHTML("beforeend", newItem);

        closeModal();

        document.getElementById("name").value = "";
        document.getElementById("role").value = "";
        document.getElementById("message").value = "";
    }
</script>